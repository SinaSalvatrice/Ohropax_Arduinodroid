#include <Arduino.h>
#include <HID-Project.h>
#include <Adafruit_NeoPixel.h>

// ============================================================
// MINI-QMK ARDUINO PAD
// - 2x3 matrix
// - encoder
// - encoder button in matrix
// - layer-based keymap
// - QMK-style KC aliases
// - QMK-style LAYOUT(...) macro
// - MO(layer) and TG(layer)
// - dark RGB breathing
// - serial shows active row/col pins
// ============================================================


// ============================================================
// CONFIG
// ============================================================
const uint8_t MATRIX_ROWS = 2;
const uint8_t MATRIX_COLS = 3;

// Matrix: ROW -> COL scan
const uint8_t rowPins[MATRIX_ROWS] = {2, 3};
const uint8_t colPins[MATRIX_COLS] = {6, 5, 4};

// Encoder
const uint8_t ENC_A = 10;
const uint8_t ENC_B = 14;

// Encoder button position in matrix
const uint8_t ENC_BTN_ROW = 0;
const uint8_t ENC_BTN_COL = 2;

// RGB
const uint8_t LED_PIN = A3;
const uint8_t LED_COUNT = 6;

// Timing
const uint16_t MATRIX_DEBOUNCE_MS = 20;
const uint8_t ENC_STEPS_PER_DETENT = 4;
const uint16_t LED_UPDATE_MS = 20;

// RGB brightness
const uint8_t LED_BRIGHTNESS_DEFAULT = 18;
const uint8_t LED_BRIGHTNESS_MIN = 0;
const uint8_t LED_BRIGHTNESS_MAX = 100;
const uint8_t LED_BRIGHTNESS_STEP = 4;


